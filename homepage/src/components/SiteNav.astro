---
const REPO_URL = 'https://github.com/green-plan/live-talker';
---

<header class="relative z-20 mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6 sm:px-8">
	<a href="#top" class="flex items-center gap-2.5 text-lg font-extrabold tracking-tight text-white">
		live<span class="text-cyan-400">—</span>talker
		<span
			class="rounded-full border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 font-mono text-[10px] font-bold tracking-widest text-amber-300"
		>
			⚠ POC
		</span>
	</a>
	<nav class="hidden items-center gap-8 text-sm font-medium text-slate-400 sm:flex">
		<a href="#delay" class="transition hover:text-white">The delay</a>
		<a href="#crew" class="transition hover:text-white">The crew</a>
		<a href="#payoff" class="transition hover:text-white">The payoff</a>
	</nav>
	<a
		href={REPO_URL}
		target="_blank"
		rel="noopener noreferrer"
		class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:border-cyan-400/50 hover:text-white"
	>
		<svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4">
			<path
				d="M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.49c-2.22.48-2.69-1.07-2.69-1.07-.36-.93-.89-1.17-.89-1.17-.72-.5.06-.49.06-.49.8.06 1.23.83 1.23.83.71 1.23 1.87.87 2.33.67.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 0Z"
			/>
		</svg>
		View on GitHub
	</a>
</header>
