---
// Two-track timeline, matching docs/images/lag.png: LIVE MATCH races ahead,
// COMMENTARY trails a few seconds behind on the same track — by the time the
// viewer's (already-delayed) stream catches up to a moment, the matching line
// of commentary has had time to be written and rendered, so it lands in sync.
const liveEnd = 94;
const commentaryEnd = 68;
const BEAT_SEC = 60 / 135;

const OBS_DOCS_URL = 'https://github.com/green-plan/live-talker#syncing-the-video-delay';

// The OBS usage flow — four steps, matching FullCrew's icon-ring visual
// language but as a simple linear sequence (no canvas/positioning needed
// for a straight line of steps).
const commonAttrs = 'fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"';
const steps = [
	{
		label: 'Run with the overlay',
		caption: 'npm run dev:overlay',
		icon: `<rect x="3" y="4" width="18" height="16" rx="2" ${commonAttrs}/><path ${commonAttrs} d="M7 9l3 3-3 3"/><path ${commonAttrs} d="M12 15h5"/>`,
	},
	{
		label: 'Add a Browser Source',
		caption: 'point it at localhost:3002',
		icon: `<rect x="3" y="5" width="18" height="14" rx="2" ${commonAttrs}/><path ${commonAttrs} d="M3 9h18"/><circle cx="6" cy="7" r="0.6" fill="currentColor" stroke="none"/><circle cx="8.5" cy="7" r="0.6" fill="currentColor" stroke="none"/>`,
	},
	{
		label: 'Check "Control Audio via OBS"',
		caption: 'isolates it as its own track',
		icon: `<path ${commonAttrs} d="M4 13v-1a8 8 0 0 1 16 0v1"/><rect x="2.5" y="13" width="4" height="6" rx="1.5" ${commonAttrs}/><rect x="17.5" y="13" width="4" height="6" rx="1.5" ${commonAttrs}/>`,
	},
	{
		label: 'Go live',
		caption: 'picture, call & audio all in sync',
		icon: `<circle cx="12" cy="12" r="2.2" ${commonAttrs}/><path ${commonAttrs} d="M7.5 7.5a6.4 6.4 0 0 0 0 9"/><path ${commonAttrs} d="M16.5 7.5a6.4 6.4 0 0 1 0 9"/><path ${commonAttrs} d="M4.5 4.5a11 11 0 0 0 0 15"/><path ${commonAttrs} d="M19.5 4.5a11 11 0 0 1 0 15"/>`,
	},
] as const;
---

<section id="delay" class="relative px-6 pb-16 pt-4 sm:px-8">
	<div class="mx-auto max-w-2xl text-center">
		<h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
			Here's the clever part.
		</h2>
		<p class="mt-4 text-slate-400">It runs a few seconds behind the live action.</p>
	</div>

	<div class="relative mx-auto mt-10 max-w-3xl">
		<div class="flex flex-col gap-10">
			<div>
				<span class="font-mono text-xs uppercase tracking-widest text-amber-400">▸ live match</span>
				<div class="relative mt-3 h-2 rounded-full bg-slate-800">
					<div
						class="absolute inset-y-0 left-0 rounded-full bg-gradient-to-r from-amber-500/40 to-amber-400"
						style={`width:${liveEnd}%;`}
					/>
					<span
						class="beat-dot absolute top-1/2 h-3.5 w-3.5 -translate-y-1/2 rounded-full bg-amber-400 shadow-[0_0_16px_rgba(251,191,36,0.8)]"
						style={`left:calc(${liveEnd}% - 7px);`}
					/>
					<!-- second dot on the same track: the OBS stream is the same raw feed,
					     just held back to this point by the Render Delay filter — landing
					     exactly on the commentary dot below, in sync rather than racing it. -->
					<span
						class="beat-dot absolute top-1/2 h-3.5 w-3.5 -translate-y-1/2 rounded-full bg-violet-400 shadow-[0_0_16px_rgba(167,139,250,0.8)]"
						style={`left:calc(${commentaryEnd}% - 7px); animation-delay:${BEAT_SEC / 2}s;`}
					/>
					<span
						class="absolute bottom-full mb-1.5 -translate-x-1/2 whitespace-nowrap font-mono text-[10px] uppercase tracking-widest text-violet-400"
						style={`left:${commentaryEnd}%;`}
					>
						obs stream (delayed)
					</span>
				</div>
			</div>

			<div>
				<span class="font-mono text-xs uppercase tracking-widest text-cyan-400">▸ commentary</span>
				<div class="relative mt-3 h-2 rounded-full bg-slate-800">
					<div
						class="absolute inset-y-0 left-0 rounded-full bg-gradient-to-r from-cyan-500/40 to-cyan-400"
						style={`width:${commentaryEnd}%;`}
					/>
					<!-- pulses one beat behind the live dot — the same delay this whole
					     section is explaining, made visible in the animation itself. -->
					<span
						class="beat-dot absolute top-1/2 h-3.5 w-3.5 -translate-y-1/2 rounded-full bg-cyan-400 shadow-[0_0_16px_rgba(0,196,224,0.8)]"
						style={`left:calc(${commentaryEnd}% - 7px); animation-delay:${BEAT_SEC / 2}s;`}
					/>
				</div>
			</div>
		</div>

		<!-- gap annotation: dotted connector dropping from the live dot down to the
		     commentary track, labeled with the realized delay. -->
		<div
			class="pointer-events-none absolute top-[6px] h-[88px] border-l border-dashed border-amber-400/50"
			style={`left:${liveEnd}%;`}
		>
			<span
				class="absolute top-1/2 left-3 -translate-y-1/2 whitespace-nowrap text-lg font-extrabold text-amber-400"
			>
				~3s
			</span>
		</div>

		<!-- second connector: the delayed OBS dot and the commentary dot share the
		     same x position, so this one is short and solid — visually "zero gap" to
		     make the in-sync claim literal, not just stated in the caption below. -->
		<div
			class="pointer-events-none absolute top-[6px] h-[88px] border-l border-violet-400/50"
			style={`left:${commentaryEnd}%;`}
		>
			<span
				class="absolute top-1/2 left-3 -translate-y-1/2 whitespace-nowrap text-sm font-bold text-violet-400"
			>
			</span>
		</div>
	</div>

	<p class="mx-auto mt-10 max-w-xl text-center text-sm text-slate-500">
		By the time a moment reaches the (already-delayed) stream, the line describing it has had time
		to be written and voiced — so commentary always lands in sync, never racing to catch up. On
		stream that means only the <em>game</em> feed needs holding back by the same amount; a global
		OBS stream delay won't do it —
		<a href={OBS_DOCS_URL} target="_blank" rel="noopener noreferrer" class="text-cyan-400 underline-offset-2 hover:underline">full setup in the README</a>.
	</p>

	<!-- OBS / overlay usage flow — the part that's easy to get lost on: this isn't
	     just a delay number to type into OBS, there's a whole second piece (the
	     browser overlay) that gives the commentary its own isolated audio track. -->
	<div class="mx-auto mt-20 max-w-4xl">
		<div class="mx-auto max-w-2xl text-center">
			<span class="font-mono text-xs uppercase tracking-widest text-cyan-400">
				<span class="beat-dot inline-block">●</span> streaming with obs
			</span>
			<h3 class="mt-3 text-2xl font-extrabold tracking-tight text-white sm:text-3xl">
				Give the commentary its own track.
			</h3>
			<p class="mt-4 text-slate-400">
				By default the caster's voice just plays on the desktop, mixed in with everything else. The
				<strong class="text-slate-200">browser overlay</strong> gives it its own clean track instead
				— a small page OBS treats as a video+audio source, with a live waveform and a running log
				of every line called.
			</p>
		</div>

		<!-- the four-step flow -->
		<div class="mt-10 flex flex-col items-stretch gap-3 md:flex-row md:items-center md:gap-2">
			{steps.map((step, i) => (
				<>
					<div class="flex flex-1 flex-col items-center gap-3 rounded-2xl border border-slate-800 bg-slate-900/60 p-5 text-center">
						<div class="relative">
							<div class="beat-glow absolute inset-0 rounded-full bg-cyan-400/25 blur-lg" style={`animation-delay:${(i * BEAT_SEC) / steps.length}s;`}></div>
							<div class="beat-ring relative flex h-12 w-12 items-center justify-center rounded-full border border-cyan-400/40 bg-slate-900 text-cyan-300" style={`animation-delay:${(i * BEAT_SEC) / steps.length}s;`}>
								<svg viewBox="0 0 24 24" class="h-6 w-6" set:html={step.icon} />
							</div>
						</div>
						<p class="text-sm font-bold text-white">{step.label}</p>
						<p class="font-mono text-[11px] text-slate-500">{step.caption}</p>
					</div>
					{i < steps.length - 1 && (
						<div class="flex items-center justify-center text-cyan-400/50 md:px-0">
							<svg viewBox="0 0 24 24" class="h-5 w-5 rotate-90 md:rotate-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M5 12h14M13 6l6 6-6 6" />
							</svg>
						</div>
					)}
				</>
			))}
		</div>

		<div class="mt-12 flex flex-col items-center">
			<a
				href="https://github.com/green-plan/live-talker#broadcasting-with-obs"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-1.5 rounded-full border border-slate-700 bg-slate-900/60 px-4 py-1.5 text-sm font-semibold text-slate-200 transition hover:border-cyan-400/50 hover:text-white"
			>
				Full OBS setup guide ↗
			</a>
		</div>
	</div>
</section>
