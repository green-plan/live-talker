---
// Deterministic "waveform" heights — a few stacked sine waves so it reads as
// organic audio rather than a uniform bar chart, with no client JS needed.
// Each bar also gets a tiny staggered animation-delay (still locked to the
// 135 BPM beat-bar keyframe in Layout.astro) so the whole row reads as a
// playing equalizer rather than a static graphic.
const BEAT_SEC = 60 / 135;
const bars = Array.from({ length: 48 }, (_, i) => {
	const h =
		34 +
		28 * Math.abs(Math.sin(i * 0.45)) +
		18 * Math.abs(Math.sin(i * 0.12 + 1.5));
	return { height: Math.min(100, Math.round(h)), delay: (i % 4) * (BEAT_SEC / 4) };
});
---

<section id="payoff" class="relative px-6 py-16 sm:px-8">
	<div class="mx-auto max-w-2xl text-center">
		<span class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-cyan-400">
			<span class="beat-dot h-1.5 w-1.5 rounded-full bg-cyan-400"></span> the payoff
		</span>
		<h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
			A full commentary track.
		</h2>
		<p class="mt-4 text-slate-400">
			Every round, stitched into one continuous broadcast — synced to the action, never out of
			order, never silent when it shouldn't be.
		</p>
	</div>

	<div class="mx-auto mt-10 max-w-2xl">
		<div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6 shadow-[0_0_60px_rgba(15,23,42,0.6)]">
			<div class="flex h-24 items-end gap-[3px]">
				{bars.map(({ height, delay }) => (
					<span
						class="beat-bar flex-1 rounded-full bg-gradient-to-t from-cyan-500/40 to-cyan-300"
						style={`height:${height}%; animation-delay:${delay}s;`}
					/>
				))}
			</div>
			<div class="mt-4 flex items-center justify-between font-mono text-xs text-slate-500">
				<span>commentary_session.mp3</span>
				<span class="text-cyan-400">1:23</span>
			</div>
		</div>

		<div class="mt-5 flex flex-wrap items-center justify-center gap-3">
			<span
				class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-4 py-1.5 font-mono text-xs text-slate-300"
			>
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-3.5 w-3.5">
					<rect x="3" y="5" width="18" height="14" rx="2" stroke-linecap="round" stroke-linejoin="round" />
					<path d="M3 9h18M8 15h3" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
				subtitles included
			</span>
		</div>

		<p class="mt-4 flex items-center justify-center gap-2 text-sm font-medium text-cyan-400">
			<span>✓</span> saved · ready to relive, anytime
		</p>
	</div>
</section>
