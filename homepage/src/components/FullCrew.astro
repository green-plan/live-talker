---
// Matches docs/images/full_crew.png — the full pipeline, named like a tiny
// broadcast crew. Coordinates are hand-placed percentages on a fixed-height
// canvas (desktop only; mobile gets a simple stacked list of the same data).
const commonAttrs = 'fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"';

// The seven roles that actually pass the moment hand to hand.
const nodes = [
	{
		key: 'listener',
		label: 'The Listener',
		caption: 'catches every event',
		top: 50,
		left: 10.5,
		icon: `<path ${commonAttrs} d="M2 9a14 14 0 0 1 20 0"/><path ${commonAttrs} d="M5.5 12.8a9.5 9.5 0 0 1 13 0"/><path ${commonAttrs} d="M9 16.5a5 5 0 0 1 6 0"/><circle cx="12" cy="20" r="1.2" fill="currentColor" stroke="none"/>`,
	},
	{
		key: 'memory',
		label: 'The Memory',
		caption: 'holds the match state',
		top: 14,
		left: 25.5,
		icon: `<circle cx="6" cy="6" r="1.1" fill="currentColor" stroke="none"/><circle cx="12" cy="6" r="1.1" fill="currentColor" stroke="none"/><circle cx="18" cy="6" r="1.1" fill="currentColor" stroke="none"/><circle cx="6" cy="12" r="1.1" fill="currentColor" stroke="none"/><circle cx="12" cy="12" r="1.1" fill="currentColor" stroke="none"/><circle cx="18" cy="12" r="1.1" fill="currentColor" stroke="none"/><circle cx="6" cy="18" r="1.1" fill="currentColor" stroke="none"/><circle cx="12" cy="18" r="1.1" fill="currentColor" stroke="none"/><circle cx="18" cy="18" r="1.1" fill="currentColor" stroke="none"/>`,
	},
	{
		key: 'map-reader',
		label: 'The Map Reader',
		caption: 'names the position',
		top: 14,
		left: 40.5,
		icon: `<path ${commonAttrs} d="M12 22s7-7.58 7-12A7 7 0 0 0 5 10c0 4.42 7 12 7 12Z"/><circle cx="12" cy="10" r="2.4" ${commonAttrs}/>`,
	},
	{
		key: 'analyst',
		label: 'The Analyst',
		caption: 'finds the moment',
		top: 50,
		left: 32.5,
		icon: `<circle cx="11" cy="11" r="7" ${commonAttrs}/><path ${commonAttrs} d="M21 21l-4.3-4.3"/>`,
	},
	{
		key: 'storyteller',
		label: 'The Storyteller',
		caption: 'writes the line',
		top: 58,
		left: 53.5,
		icon: `<path ${commonAttrs} d="M6 3h9l4 4v14H6Z"/><path ${commonAttrs} d="M9 10h7M9 14h7M9 18h4"/>`,
	},
	{
		key: 'voice',
		label: 'The Voice',
		caption: 'brings it to life',
		top: 26,
		left: 70.5,
		icon: `<path ${commonAttrs} d="M12 1.5a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0v-7a3 3 0 0 0-3-3Z"/><path ${commonAttrs} d="M18.5 11v.5a6.5 6.5 0 0 1-13 0V11"/><path ${commonAttrs} d="M12 18v3.5M9 21.5h6"/>`,
	},
	{
		key: 'archivist',
		label: 'The Archivist',
		caption: 'saves the broadcast',
		top: 58,
		left: 89.5,
		icon: `<path ${commonAttrs} d="M3.5 7h17v3.5h-17Z"/><path ${commonAttrs} d="M5 10.5v9.5h14v-9.5"/><path ${commonAttrs} d="M9.5 14h5"/>`,
	},
] as const;

const connector = { top: 40, left: 80.5 };
const badge = { top: 50, left: 43.5 };
const GLOW_CYCLE_SEC = 0.889; // matches .beat-glow/.beat-ring in Layout.astro — 2 beats at 135 BPM

// The main signal path — what actually flows beat-to-clip.
const lines: [number, number][] = [
	[0, 3], // Listener – Analyst
	[3, 1], // Analyst – Memory
	[3, 2], // Analyst – Map Reader
	[3, 4], // Analyst – Storyteller
	[4, 5], // Storyteller – Voice
	[5, 6], // Voice – Archivist (passes behind the connector glyph)
];

// The Conductor sits apart from that chain entirely — a single brace spanning
// underneath the whole crew, not a line to any one member, so it reads as
// "oversees all of this" rather than "hands off to this".
const braceLeft = nodes[0].left; // Listener
const braceRight = nodes[6].left; // Archivist
const braceY = 84;
const conductor = { top: 95, left: (braceLeft + braceRight) / 2 };
---

<section id="crew" class="relative px-6 py-16 sm:px-8">
	<div class="mx-auto max-w-2xl text-center">
		<span class="font-mono text-xs uppercase tracking-widest text-cyan-400">
			<span class="beat-dot inline-block">●</span> meet the crew
		</span>
		<h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
			Eight tiny systems, one live caster.
		</h2>
		<p class="mx-auto mt-4 max-w-2xl text-slate-400">
			Seven of them pass the moment hand to hand — catching events, remembering state, reading
			the map, spotting what matters, writing the line, voicing it, and saving the tape. The
			eighth, the Conductor, doesn't touch any of that — it just keeps the whole crew in time.
		</p>
	</div>

	<!-- desktop pipeline diagram -->
	<div class="relative mx-auto mt-12 hidden h-[600px] max-w-6xl md:block">
		<svg class="absolute inset-0 h-full w-full overflow-visible" viewBox="0 0 100 100" preserveAspectRatio="none">
			{lines.map(([a, b]) => (
				<line
					x1={nodes[a].left}
					y1={nodes[a].top}
					x2={nodes[b].left}
					y2={nodes[b].top}
					stroke="rgb(56 189 248 / 0.35)"
					stroke-width="0.35"
					stroke-dasharray="1.2 1.2"
				/>
			))}

			<!-- the Conductor's brace: a wide bracket under the whole crew, with a
			     single stem dropping to the Conductor itself. -->
			<path
				d={`M ${braceLeft} 73 V ${braceY} H ${braceRight} V 73`}
				fill="none"
				stroke="rgb(56 189 248 / 0.3)"
				stroke-width="0.3"
				stroke-dasharray="1.2 1.2"
			/>
			<line
				x1={conductor.left}
				y1={braceY}
				x2={conductor.left}
				y2={conductor.top}
				stroke="rgb(56 189 248 / 0.3)"
				stroke-width="0.3"
				stroke-dasharray="1.2 1.2"
			/>
		</svg>

		{nodes.map((node, i) => (
			<div
				class="absolute flex -translate-x-1/2 -translate-y-1/2 flex-col items-center text-center"
				style={`top:${node.top}%; left:${node.left}%;`}
			>
				<div class="relative">
					<div
						class="beat-glow absolute inset-0 rounded-full bg-cyan-400/25 blur-xl"
						style={`animation-delay:${(i * GLOW_CYCLE_SEC) / nodes.length}s;`}
					></div>
					<div
						class="beat-ring relative flex h-16 w-16 items-center justify-center rounded-full border border-cyan-400/40 bg-slate-900 text-cyan-300"
						style={`animation-delay:${(i * GLOW_CYCLE_SEC) / nodes.length}s;`}
					>
						<svg viewBox="0 0 24 24" class="h-7 w-7" set:html={node.icon} />
					</div>
				</div>
				<p class="mt-3 whitespace-nowrap text-sm font-bold text-white">{node.label}</p>
				<p class="whitespace-nowrap font-mono text-[11px] text-slate-500">{node.caption}</p>
			</div>
		))}

		<!-- small connector glyph between Voice and the Archivist -->
		<div
			class="absolute flex h-8 w-8 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-md border border-cyan-400/30 bg-slate-900 text-cyan-300"
			style={`top:${connector.top}%; left:${connector.left}%;`}
		>
			<svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
				<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z" />
			</svg>
		</div>

		<!-- event flowing through the pipe -->
		<div
			class="absolute -translate-x-1/2 -translate-y-1/2 rounded-md border border-cyan-400/30 bg-slate-950 px-2 py-1 font-mono text-[10px] font-bold text-cyan-300"
			style={`top:${badge.top}%; left:${badge.left}%;`}
		>
			BOMB&nbsp;‹&nbsp;A
		</div>

		<!-- the Conductor — set apart from the crew row, larger ring, label
		     above (it sits too low for a label below to fit on the canvas). -->
		<div
			class="absolute flex -translate-x-1/2 -translate-y-1/2 flex-col items-center text-center"
			style={`top:${conductor.top}%; left:${conductor.left}%;`}
		>
			<p class="-mt-1 mb-2 whitespace-nowrap text-sm font-bold text-white">The Conductor</p>
			<div class="relative">
				<div class="absolute -inset-3 rounded-full border border-dashed border-cyan-400/30"></div>
				<div class="beat-glow absolute inset-0 rounded-full bg-cyan-400/30 blur-xl"></div>
				<div
					class="beat-ring relative flex h-16 w-16 items-center justify-center rounded-full border border-cyan-400/50 bg-slate-900 text-cyan-300"
				>
					<svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="8.5" />
						<path d="M12 7.5V12l3 2" />
					</svg>
				</div>
			</div>
			<p class="mt-2 whitespace-nowrap font-mono text-[11px] text-slate-500">oversees the whole crew</p>
		</div>
	</div>

	<!-- mobile stacked fallback -->
	<div class="mx-auto mt-10 grid max-w-sm gap-4 md:hidden">
		{nodes.map((node) => (
			<div class="flex items-center gap-4 rounded-2xl border border-slate-800 bg-slate-900/60 p-4">
				<div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full border border-cyan-400/40 bg-slate-900 text-cyan-300">
					<svg viewBox="0 0 24 24" class="h-6 w-6" set:html={node.icon} />
				</div>
				<div class="text-left">
					<p class="text-sm font-bold text-white">{node.label}</p>
					<p class="font-mono text-xs text-slate-500">{node.caption}</p>
				</div>
			</div>
		))}
		<div class="mt-2 flex items-center gap-4 rounded-2xl border border-dashed border-cyan-400/30 bg-slate-900/60 p-4">
			<div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full border border-cyan-400/50 bg-slate-900 text-cyan-300">
				<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="8.5" />
					<path d="M12 7.5V12l3 2" />
				</svg>
			</div>
			<div class="text-left">
				<p class="text-sm font-bold text-white">The Conductor</p>
				<p class="font-mono text-xs text-slate-500">oversees the whole crew</p>
			</div>
		</div>
	</div>
</section>
