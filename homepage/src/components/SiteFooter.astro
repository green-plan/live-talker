---
const REPO_URL = 'https://github.com/green-plan/live-talker';
---

<footer class="relative border-t border-slate-900 px-6 py-10 sm:px-8">
	<div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
		<p class="text-sm font-bold text-white">
			live<span class="text-cyan-400">—</span>talker
		</p>
		<p class="font-mono text-xs text-slate-500">a tiny AI broadcast crew · open-source · proof of concept</p>
		<a href={REPO_URL} target="_blank" rel="noopener noreferrer" class="text-sm text-slate-400 transition hover:text-white">
			GitHub ↗
		</a>
	</div>
	<p class="mx-auto mt-4 max-w-6xl text-center font-mono text-[11px] text-slate-600">
		<a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/third-party-licenses.txt`} class="transition hover:text-slate-400">
			Built on Open Source
		</a>
	</p>
</footer>
