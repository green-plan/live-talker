{
  "name": "live-talker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "replay": "tsx scripts/replay.ts temp/gsi-dump.jsonl",
    "replay:fast": "tsx scripts/replay.ts --fast temp/gsi-dump.jsonl",
    "tts": "tsx scripts/tts.ts"
  },
  "vitest": {
    "environment": "node"
  },
  "dependencies": {
    "csgogsi": "^5.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sound-play": "^1.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
