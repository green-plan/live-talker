# Copy to .env. Everything has a sane default baked into the code; uncomment
# a line below only to override it. See the README for what each variable does.

# Optional — leave blank and set MOCK=true below to run with no API key and no
# cost. If you do set a real key, this code has not been hardened or audited
# against bugs that could cause unintended/excessive API calls — the OPENROUTER_*
# limits below are a basic backstop, not a budget guarantee. Only use a key with a
# spend limit, and you are responsible for any charges incurred. Pricing varies by
# model — check OpenRouter's current pricing for whichever model you configure
# below (OPENROUTER_LLM_MODEL / OPENROUTER_TTS_MODEL), not just the defaults.
OPENROUTER_API_KEY=

# PORT=3000
# MOCK=true
# MOCK_TEXT=true
# MOCK_SPEECH=true
# MOCK_TEXT_DELAY_MS=900
# MOCK_SPEECH_DELAY_MS=900
# TTS_MODE=gemini
# LOG_LEVEL=debug
# RECORD_BROADCAST=true
# OVERLAY=false
# OVERLAY_PORT=3002
# OPENROUTER_MAX_CALLS_PER_SESSION=2000
# OPENROUTER_RATE_LIMIT_PER_MINUTE=60
# OPENROUTER_MAX_REQUEST_CHARS=64000
# OPENROUTER_LLM_MODEL=google/gemini-3.5-flash
# OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
